@model Order
@{
    ViewData["Title"] = "Chi tiet đơn hàng #" + Model.Id;
}

@section Styles {
<style>
    .detail-card {
        border-radius: 14px;
        background: #fff;
    }
    .detail-card .card-header {
        background: none;
        border-bottom: 1px solid #f3f4f6;
        padding: 18px 22px;
    }
    .detail-card .card-body {
        padding: 22px;
    }
    .info-row {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid #f9fafb;
    }
    .info-row:last-child {
        border-bottom: none;
    }
    .info-label {
        width: 140px;
        font-size: 0.85rem;
        color: #6b7280;
        font-weight: 500;
        flex-shrink: 0;
    }
    .info-value {
        font-size: 0.9rem;
        color: #1f2937;
        font-weight: 500;
    }
    .item-table th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        font-weight: 600;
        border-bottom: 2px solid #f3f4f6;
        padding: 14px 16px;
    }
    .item-table td {
        vertical-align: middle;
        padding: 14px 16px;
        font-size: 0.88rem;
    }
    .item-table tbody tr:hover {
        background: #fff7ed;
    }
    .item-thumb {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        object-fit: cover;
        border: 2px solid #f3f4f6;
    }
    .item-thumb-placeholder {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        background: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #d1d5db;
    }
    .total-row {
        background: #fff7ed;
    }
    .total-amount {
        font-size: 1.3rem;
        font-weight: 800;
        color: #FF6B35;
    }
    .status-update-card {
        border-radius: 14px;
        background: #fff;
        border: 2px solid #f3f4f6;
    }
    .status-badge-lg {
        font-size: 0.9rem;
        padding: 8px 18px;
        border-radius: 25px;
        font-weight: 600;
    }
    .btn-update {
        background: #FF6B35;
        border-color: #FF6B35;
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    .btn-update:hover {
        background: #e85a24;
        border-color: #e85a24;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(255,107,53,0.3);
    }
    .btn-back {
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        border: 1px solid #d1d5db;
        color: #6b7280;
        background: #fff;
        font-size: 0.9rem;
    }
    .btn-back:hover {
        background: #f3f4f6;
        color: #374151;
    }
</style>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Đơn hàng #@Model.Id</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Dat ngay @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-back">
        <i class="fas fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-lg-8">
        <!-- Customer Info -->
        <div class="card detail-card mb-4">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="fas fa-user me-2" style="color:#FF6B35;"></i>Thong tin khách hàng</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <span class="info-label">Khách hàng</span>
                            <span class="info-value">@Model.User.FullName</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Email</span>
                            <span class="info-value">@Model.User.Email</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">So điện thoại</span>
                            <span class="info-value">@Model.PhoneNumber</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <span class="info-label">Địa chỉ giao</span>
                            <span class="info-value">@Model.ShippingAddress</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Thanh toán</span>
                            <span class="info-value">
                                @if (Model.PaymentMethod == PaymentMethod.COD)
                                {
                                    <span class="badge" style="background:#f3f4f6;color:#6b7280;border-radius:20px;padding:5px 12px;">COD</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#e0f2fe;color:#0284c7;border-radius:20px;padding:5px 12px;">Chuyển khoản</span>
                                }
                            </span>
                        </div>
                        @if (Model.PaymentMethod == PaymentMethod.BankTransfer)
                        {
                            <div class="info-row">
                                <span class="info-label">Trạng thái TT</span>
                                <span class="info-value">
                                    @if (Model.IsPaid)
                                    {
                                        <span class="badge" style="background:#dcfce7;color:#16a34a;border-radius:20px;padding:5px 12px;">
                                            <i class="fas fa-check-circle me-1"></i>Đã thanh toán
                                        </span>
                                        if (Model.PaidAt.HasValue)
                                        {
                                            <small class="text-muted ms-2">@Model.PaidAt.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#fee2e2;color:#dc2626;border-radius:20px;padding:5px 12px;">
                                            <i class="fas fa-clock me-1"></i>Chưa thanh toán
                                        </span>
                                        <form asp-area="Admin" asp-controller="Order" asp-action="MarkPaid" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm text-white" style="background:linear-gradient(135deg,#10b981,#059669); border-radius:8px; padding:4px 12px;" onclick="return confirm('Xác nhận đơn này đã được thanh toán?')">
                                                <i class="fas fa-check me-1"></i>Xác nhận đã TT
                                            </button>
                                        </form>
                                    }
                                </span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="info-row">
                                <span class="info-label">Ghi chú</span>
                                <span class="info-value fst-italic">@Model.Note</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Items -->
        <div class="card detail-card">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="fas fa-list me-2" style="color:#FF6B35;"></i>Chi tiet sản phẩm</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table item-table mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="item-thumb"
                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';" />
                                                <span class="item-thumb-placeholder" style="display:none;">
                                                    <i class="fas fa-image"></i>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="item-thumb-placeholder">
                                                    <i class="fas fa-image"></i>
                                                </span>
                                            }
                                            <strong>@item.Product.Name</strong>
                                        </div>
                                    </td>
                                    <td>@item.UnitPrice.ToString("N0") đ</td>
                                    <td><span class="badge" style="background:#f3f4f6;color:#374151;border-radius:8px;padding:4px 12px;font-size:0.85rem;">x@item.Quantity</span></td>
                                    <td><strong>@((item.UnitPrice * item.Quantity).ToString("N0")) đ</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="total-row">
                                <td colspan="3" class="text-end pe-3">
                                    <strong style="font-size:0.95rem;">Tổng cộng:</strong>
                                </td>
                                <td>
                                    <span class="total-amount">@Model.TotalAmount.ToString("N0") đ</span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column - Status Update -->
    <div class="col-lg-4">
        <div class="card status-update-card">
            <div class="card-header" style="background:none;border-bottom:1px solid #f3f4f6;padding:18px 22px;">
                <h6 class="mb-0 fw-bold"><i class="fas fa-sync-alt me-2" style="color:#FF6B35;"></i>Trạng thái đơn hàng</h6>
            </div>
            <div class="card-body" style="padding:22px;">
                <div class="text-center mb-4 p-3" style="background:#f9fafb;border-radius:12px;">
                    <small class="text-muted d-block mb-2">Trạng thái hien tai</small>
                    @switch (Model.Status)
                    {
                        case OrderStatus.ChoXacNhan:
                            <span class="status-badge-lg badge bg-warning text-dark">Chờ xác nhận</span>
                            break;
                        case OrderStatus.DaXacNhan:
                            <span class="status-badge-lg badge bg-info">Đã xác nhận</span>
                            break;
                        case OrderStatus.DangGiao:
                            <span class="status-badge-lg badge bg-primary">Đang giao</span>
                            break;
                        case OrderStatus.HoanThanh:
                            <span class="status-badge-lg badge bg-success">Hoàn thành</span>
                            break;
                        case OrderStatus.DaHuy:
                            <span class="status-badge-lg badge bg-danger">Đã hủy</span>
                            break;
                    }
                </div>

                <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:0.85rem;color:#374151;">Trạng thái moi</label>
                        <select name="status" class="form-select" style="border-radius:10px;padding:10px 14px;">
                            <option value="@OrderStatus.ChoXacNhan" selected="@(Model.Status == OrderStatus.ChoXacNhan)">Chờ xác nhận</option>
                            <option value="@OrderStatus.DaXacNhan" selected="@(Model.Status == OrderStatus.DaXacNhan)">Đã xác nhận</option>
                            <option value="@OrderStatus.DangGiao" selected="@(Model.Status == OrderStatus.DangGiao)">Đang giao</option>
                            <option value="@OrderStatus.HoanThanh" selected="@(Model.Status == OrderStatus.HoanThanh)">Hoàn thành</option>
                            <option value="@OrderStatus.DaHuy" selected="@(Model.Status == OrderStatus.DaHuy)">Đã hủy</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary btn-update w-100">
                        <i class="fas fa-save me-1"></i> Cập nhật trạng thái
                    </button>
                </form>
            </div>
        </div>

        <!-- Order Tìmeline -->
        <div class="card mt-4" style="border-radius:14px;">
            <div class="card-body" style="padding:22px;">
                <h6 class="fw-bold mb-3" style="font-size:0.85rem;"><i class="fas fa-info-circle me-2" style="color:#FF6B35;"></i>Thong tin them</h6>
                <div class="info-row">
                    <span class="info-label">Mã đơn</span>
                    <span class="info-value">#@Model.Id</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Ngày đặt</span>
                    <span class="info-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="info-row">
                    <span class="info-label">So sản phẩm</span>
                    <span class="info-value">@Model.OrderDetails.Count sản phẩm</span>
                </div>
            </div>
        </div>

        <a asp-area="Admin" asp-controller="Order" asp-action="Index"
           class="btn btn-back w-100 mt-3">
            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sach
        </a>
    </div>
</div>
