@model Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="row">
    <!-- Order Info -->
    <div class="col-lg-8 mb-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-info-circle"></i> Thông tin đơn hàng #@Model.Id</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Khách hàng:</strong> @Model.User.FullName</p>
                        <p><strong>Email:</strong> @Model.User.Email</p>
                        <p><strong>Số điện thoại:</strong> @Model.PhoneNumber</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Địa chỉ giao:</strong> @Model.ShippingAddress</p>
                        <p><strong>Thanh toán:</strong>
                            @if (Model.PaymentMethod == PaymentMethod.COD)
                            {
                                <span>Thanh toán khi nhận hàng (COD)</span>
                            }
                            else
                            {
                                <span>Chuyển khoản ngân hàng</span>
                            }
                        </p>
                        <p><strong>Ngày đặt:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <p><strong>Ghi chú:</strong> @Model.Note</p>
                }
            </div>
        </div>

        <!-- Order Items -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-list"></i> Chi tiết sản phẩm</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name"
                                                     style="width:40px;height:40px;object-fit:cover;" class="rounded me-2" />
                                            }
                                            @item.Product.Name
                                        </div>
                                    </td>
                                    <td>@item.UnitPrice.ToString("N0") đ</td>
                                    <td>@item.Quantity</td>
                                    <td><strong>@((item.UnitPrice * item.Quantity).ToString("N0")) đ</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                                <td><strong class="text-danger fs-5">@Model.TotalAmount.ToString("N0") đ</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Update -->
    <div class="col-lg-4 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-sync"></i> Cập nhật trạng thái</h5>
            </div>
            <div class="card-body">
                <p class="mb-2">Trạng thái hiện tại:</p>
                <p class="mb-3">
                    @switch (Model.Status)
                    {
                        case OrderStatus.ChoXacNhan:
                            <span class="badge bg-warning text-dark fs-6">Chờ xác nhận</span>
                            break;
                        case OrderStatus.DaXacNhan:
                            <span class="badge bg-info fs-6">Đã xác nhận</span>
                            break;
                        case OrderStatus.DangGiao:
                            <span class="badge bg-primary fs-6">Đang giao</span>
                            break;
                        case OrderStatus.HoanThanh:
                            <span class="badge bg-success fs-6">Hoàn thành</span>
                            break;
                        case OrderStatus.DaHuy:
                            <span class="badge bg-danger fs-6">Đã hủy</span>
                            break;
                    }
                </p>
                <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                    <div class="mb-3">
                        <label class="form-label">Trạng thái mới</label>
                        <select name="status" class="form-select">
                            <option value="@OrderStatus.ChoXacNhan" selected="@(Model.Status == OrderStatus.ChoXacNhan)">Chờ xác nhận</option>
                            <option value="@OrderStatus.DaXacNhan" selected="@(Model.Status == OrderStatus.DaXacNhan)">Đã xác nhận</option>
                            <option value="@OrderStatus.DangGiao" selected="@(Model.Status == OrderStatus.DangGiao)">Đang giao</option>
                            <option value="@OrderStatus.HoanThanh" selected="@(Model.Status == OrderStatus.HoanThanh)">Hoàn thành</option>
                            <option value="@OrderStatus.DaHuy" selected="@(Model.Status == OrderStatus.DaHuy)">Đã hủy</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-save"></i> Cập nhật
                    </button>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-secondary w-100">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>
