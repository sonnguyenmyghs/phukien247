@model List<Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<h5 class="mb-3">Danh sách đơn hàng</h5>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Khách hàng</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ giao</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.Id</td>
                            <td>@order.User.FullName</td>
                            <td>@order.PhoneNumber</td>
                            <td>
                                <span title="@order.ShippingAddress">
                                    @(order.ShippingAddress.Length > 30 ? order.ShippingAddress.Substring(0, 30) + "..." : order.ShippingAddress)
                                </span>
                            </td>
                            <td><strong>@order.TotalAmount.ToString("N0") đ</strong></td>
                            <td>
                                @if (order.PaymentMethod == PaymentMethod.COD)
                                {
                                    <span class="badge bg-secondary">COD</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Chuyển khoản</span>
                                }
                            </td>
                            <td>
                                @switch (order.Status)
                                {
                                    case OrderStatus.ChoXacNhan:
                                        <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                        break;
                                    case OrderStatus.DaXacNhan:
                                        <span class="badge bg-info">Đã xác nhận</span>
                                        break;
                                    case OrderStatus.DangGiao:
                                        <span class="badge bg-primary">Đang giao</span>
                                        break;
                                    case OrderStatus.HoanThanh:
                                        <span class="badge bg-success">Hoàn thành</span>
                                        break;
                                    case OrderStatus.DaHuy:
                                        <span class="badge bg-danger">Đã hủy</span>
                                        break;
                                }
                            </td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">Chưa có đơn hàng nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
