@model List<Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var search = ViewBag.Search as string;
    int? selectedStatus = ViewBag.Status;
    DateTime? fromDate = ViewBag.FromDate;
    DateTime? toDate = ViewBag.ToDate;
}

@section Styles {
<style>
    .order-table th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        font-weight: 600;
        border-bottom: 2px solid #f3f4f6;
        padding: 14px 16px;
        white-space: nowrap;
    }
    .order-table td {
        vertical-align: middle;
        padding: 12px 16px;
        font-size: 0.88rem;
    }
    .order-table tbody tr {
        transition: background 0.15s;
    }
    .order-table tbody tr:nth-child(even) {
        background: #fafbfc;
    }
    .order-table tbody tr:hover {
        background: #fff7ed;
    }
    .status-badge {
        font-size: 0.78rem;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
    .filter-select {
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        padding: 8px 14px;
        font-size: 0.88rem;
        min-width: 180px;
        transition: border-color 0.2s;
    }
    .filter-select:focus {
        border-color: #FF6B35;
        box-shadow: 0 0 0 3px rgba(255,107,53,0.1);
    }
    .btn-detail {
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.2s;
        border: 1px solid #FF6B35;
        color: #FF6B35;
        background: transparent;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .btn-detail:hover {
        background: #FF6B35;
        color: #fff;
    }
</style>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Quản lý đơn hàng</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">@Model.Count đơn hàng trong he thong</p>
    </div>
</div>

<!-- Filter Bar -->
<div class="card mb-4" style="border-radius:12px;">
    <div class="card-body py-3">
        <form asp-area="Admin" asp-controller="Order" asp-action="Index" method="get">
            <div class="row g-2 align-items-center">
                <div class="col-md-3">
                    <input type="text" name="search" value="@search" class="filter-select w-100" placeholder="Tìm theo SĐT, tên KH, mã ĐH..." />
                </div>
                <div class="col-md-2">
                    <select name="status" class="filter-select w-100">
                        <option value="">Tất cả trạng thái</option>
                        <option value="0" selected="@(selectedStatus == 0)">Chờ xác nhận</option>
                        <option value="1" selected="@(selectedStatus == 1)">Đã xác nhận</option>
                        <option value="2" selected="@(selectedStatus == 2)">Đang giao</option>
                        <option value="3" selected="@(selectedStatus == 3)">Hoàn thành</option>
                        <option value="4" selected="@(selectedStatus == 4)">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="date" name="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd"))" class="filter-select w-100" placeholder="Từ ngày" />
                </div>
                <div class="col-md-2">
                    <input type="date" name="toDate" value="@(toDate?.ToString("yyyy-MM-dd"))" class="filter-select w-100" placeholder="Đến ngày" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn flex-fill" style="background:#FF6B35;color:#fff;border-radius:10px;font-weight:600;padding:8px 14px;">
                        <i class="fas fa-search me-1"></i>Lọc
                    </button>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                       class="btn btn-outline-secondary" style="border-radius:10px;font-weight:600;padding:8px 14px;">
                        <i class="fas fa-undo me-1"></i>Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Orders Table -->
<div class="card" style="border-radius:14px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table order-table mb-0" id="orderTable">
                <thead>
                    <tr>
                        <th>Ma DH</th>
                        <th>Khách hàng</th>
                        <th>So điện thoại</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                        <th>Thao tac</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>@order.User.FullName</td>
                            <td class="text-muted">@order.PhoneNumber</td>
                            <td><strong style="color:#FF6B35;">@order.TotalAmount.ToString("N0") đ</strong></td>
                            <td>
                                @if (order.PaymentMethod == PaymentMethod.COD)
                                {
                                    <span class="badge" style="background:#f3f4f6;color:#6b7280;border-radius:20px;padding:5px 10px;">COD</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#e0f2fe;color:#0284c7;border-radius:20px;padding:5px 10px;">Chuyển khoản</span>
                                }
                            </td>
                            <td>
                                @switch (order.Status)
                                {
                                    case OrderStatus.ChoXacNhan:
                                        <span class="status-badge badge bg-warning text-dark">Chờ xác nhận</span>
                                        break;
                                    case OrderStatus.DaXacNhan:
                                        <span class="status-badge badge bg-info">Đã xác nhận</span>
                                        break;
                                    case OrderStatus.DangGiao:
                                        <span class="status-badge badge bg-primary">Đang giao</span>
                                        break;
                                    case OrderStatus.HoanThanh:
                                        <span class="status-badge badge bg-success">Hoàn thành</span>
                                        break;
                                    case OrderStatus.DaHuy:
                                        <span class="status-badge badge bg-danger">Đã hủy</span>
                                        break;
                                }
                            </td>
                            <td class="text-muted">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                                   class="btn-detail">
                                    <i class="fas fa-eye"></i> Chi tiet
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fas fa-receipt fa-2x mb-2 d-block" style="opacity:0.3;"></i>
                                Chưa có đơn hàng nao
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

