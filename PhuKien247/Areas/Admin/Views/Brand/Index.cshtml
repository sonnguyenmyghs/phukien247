@model List<Brand>
@{
    ViewData["Title"] = "Quản lý thương hiệu";
}

@section Styles {
<style>
    .brand-table th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        font-weight: 600;
        border-bottom: 2px solid #f3f4f6;
        padding: 14px 16px;
        white-space: nowrap;
    }
    .brand-table td {
        vertical-align: middle;
        padding: 12px 16px;
        font-size: 0.88rem;
    }
    .brand-table tbody tr {
        transition: background 0.15s;
    }
    .brand-table tbody tr:nth-child(even) {
        background: #fafbfc;
    }
    .brand-table tbody tr:hover {
        background: #fff7ed;
    }
    .brand-thumb {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        object-fit: contain;
        background: #f9fafb;
        border: 2px solid #f3f4f6;
        padding: 4px;
    }
    .brand-thumb-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #d1d5db;
    }
    .btn-action {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        transition: all 0.2s;
        border: 1px solid;
        background: transparent;
        cursor: pointer;
    }
    .btn-action-edit { color: #f59e0b; border-color: #fde68a; }
    .btn-action-edit:hover { background: #f59e0b; color: #fff; border-color: #f59e0b; }
    .btn-action-delete { color: #ef4444; border-color: #fecaca; }
    .btn-action-delete:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
    .url-cell {
        max-width: 240px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Quản lý thương hiệu</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">@Model.Count thương hiệu trong hệ thống</p>
    </div>
    <a asp-area="Admin" asp-controller="Brand" asp-action="Create"
       class="btn btn-primary d-flex align-items-center gap-2"
       style="background:#FF6B35;border-color:#FF6B35;border-radius:10px;padding:10px 20px;font-weight:600;">
        <i class="fas fa-plus"></i> Thêm thương hiệu
    </a>
</div>

<!-- Brand Table -->
<div class="card" style="border-radius:14px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table brand-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Logo</th>
                        <th>Tên thương hiệu</th>
                        <th>Logo URL</th>
                        <th>Số sản phẩm</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var brand in Model)
                    {
                        <tr>
                            <td><strong class="text-muted">@brand.Id</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(brand.LogoUrl))
                                {
                                    <img src="@brand.LogoUrl" alt="@brand.Name" class="brand-thumb"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="brand-thumb-placeholder" style="display:none;">
                                        <i class="fas fa-trademark"></i>
                                    </div>
                                }
                                else
                                {
                                    <div class="brand-thumb-placeholder">
                                        <i class="fas fa-trademark"></i>
                                    </div>
                                }
                            </td>
                            <td><strong>@brand.Name</strong></td>
                            <td class="text-muted url-cell" title="@brand.LogoUrl">@(brand.LogoUrl ?? "-")</td>
                            <td>
                                <span class="badge" style="background:#e0f2fe;color:#0284c7;border-radius:20px;padding:5px 12px;font-weight:600;">
                                    @brand.Products.Count sản phẩm
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-area="Admin" asp-controller="Brand" asp-action="Edit" asp-route-id="@brand.Id"
                                       class="btn-action btn-action-edit" title="Chỉnh sửa">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <form asp-area="Admin" asp-controller="Brand" asp-action="Delete" asp-route-id="@brand.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa thương hiệu này?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action btn-action-delete" title="Xóa">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fas fa-trademark fa-2x mb-2 d-block" style="opacity:0.3;"></i>
                                Chưa có thương hiệu nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
