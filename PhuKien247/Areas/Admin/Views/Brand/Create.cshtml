@model Brand
@{
    ViewData["Title"] = "Thêm thương hiệu";
}

@section Styles {
<style>
    .form-card { border-radius: 14px; background: #fff; }
    .form-card .card-header { background: none; border-bottom: 1px solid #f3f4f6; padding: 20px 24px; }
    .form-card .card-body { padding: 24px; }
    .form-label { font-weight: 600; font-size: 0.85rem; color: #374151; margin-bottom: 6px; }
    .form-control {
        border-radius: 10px; border: 1px solid #e5e7eb; padding: 10px 14px;
        font-size: 0.9rem; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-control:focus { border-color: #FF6B35; box-shadow: 0 0 0 3px rgba(255,107,53,0.1); }
    .btn-save {
        background: #FF6B35; border-color: #FF6B35; border-radius: 10px;
        padding: 10px 28px; font-weight: 600; transition: all 0.2s;
    }
    .btn-save:hover {
        background: #e85a24; border-color: #e85a24;
        transform: translateY(-1px); box-shadow: 0 4px 12px rgba(255,107,53,0.3);
    }
    .btn-cancel {
        border-radius: 10px; padding: 10px 28px; font-weight: 600;
        border: 1px solid #d1d5db; color: #6b7280; background: #fff;
    }
    .btn-cancel:hover { background: #f3f4f6; color: #374151; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Thêm thương hiệu mới</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Điền thông tin thương hiệu bên dưới</p>
    </div>
    <a asp-area="Admin" asp-controller="Brand" asp-action="Index" class="btn btn-cancel">
        <i class="fas fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card form-card">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="fas fa-trademark me-2" style="color:#FF6B35;"></i>Thông tin thương hiệu</h6>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Brand" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:10px;"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên thương hiệu <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Apple, Samsung, Xiaomi..." />
                        <span asp-validation-for="Name" class="text-danger" style="font-size:0.82rem;"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="LogoUrl" class="form-label">URL logo</label>
                        <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="LogoUrl" class="text-danger" style="font-size:0.82rem;"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-save">
                            <i class="fas fa-save me-1"></i> Lưu thương hiệu
                        </button>
                        <a asp-area="Admin" asp-controller="Brand" asp-action="Index" class="btn btn-cancel">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
