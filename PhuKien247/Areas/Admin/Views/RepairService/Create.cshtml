@model RepairService
@{
    ViewData["Title"] = "Thêm dịch vụ sửa chữa";
}

@section Styles {
<style>
    .form-card { border-radius: 14px; background: #fff; }
    .form-card .card-header { background: none; border-bottom: 1px solid #f3f4f6; padding: 20px 24px; }
    .form-card .card-body { padding: 24px; }
    .form-label { font-weight: 600; font-size: 0.85rem; color: #374151; margin-bottom: 6px; }
    .form-control, .form-select {
        border-radius: 10px; border: 1px solid #e5e7eb; padding: 10px 14px;
        font-size: 0.9rem; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-control:focus, .form-select:focus { border-color: #FF6B35; box-shadow: 0 0 0 3px rgba(255,107,53,0.1); }
    .btn-save {
        background: #FF6B35; border-color: #FF6B35; border-radius: 10px;
        padding: 10px 28px; font-weight: 600; transition: all 0.2s;
    }
    .btn-save:hover {
        background: #e85a24; border-color: #e85a24;
        transform: translateY(-1px); box-shadow: 0 4px 12px rgba(255,107,53,0.3);
    }
    .btn-cancel {
        border-radius: 10px; padding: 10px 28px; font-weight: 600;
        border: 1px solid #d1d5db; color: #6b7280; background: #fff;
    }
    .btn-cancel:hover { background: #f3f4f6; color: #374151; }
    .form-check-input:checked { background-color: #FF6B35; border-color: #FF6B35; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Thêm dịch vụ sửa chữa</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Điền thông tin dịch vụ bên dưới</p>
    </div>
    <a asp-area="Admin" asp-controller="RepairService" asp-action="Index" class="btn btn-cancel">
        <i class="fas fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-header">
                <h6 class="mb-0 fw-bold"><i class="fas fa-wrench me-2" style="color:#FF6B35;"></i>Thông tin dịch vụ</h6>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="RepairService" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:10px;"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên dịch vụ <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Thay màn hình iPhone" />
                        <span asp-validation-for="Name" class="text-danger" style="font-size:0.82rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả chi tiết dịch vụ..."></textarea>
                        <span asp-validation-for="Description" class="text-danger" style="font-size:0.82rem;"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label">Giá (đ) <span class="text-danger">*</span></label>
                            <input asp-for="Price" class="form-control" type="number" min="0" step="1000" />
                            <span asp-validation-for="Price" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EstimatedTime" class="form-label">Thời gian dự kiến</label>
                            <input asp-for="EstimatedTime" class="form-control" placeholder="VD: 30 phút - 2 giờ" />
                            <span asp-validation-for="EstimatedTime" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label">URL hình ảnh</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger" style="font-size:0.82rem;"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-save">
                            <i class="fas fa-save me-1"></i> Lưu dịch vụ
                        </button>
                        <a asp-area="Admin" asp-controller="RepairService" asp-action="Index" class="btn btn-cancel">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
