@model List<RepairService>
@{
    ViewData["Title"] = "Quản lý dịch vụ sửa chữa";
}

@section Styles {
<style>
    .svc-table th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        font-weight: 600;
        border-bottom: 2px solid #f3f4f6;
        padding: 14px 16px;
        white-space: nowrap;
    }
    .svc-table td {
        vertical-align: middle;
        padding: 12px 16px;
        font-size: 0.88rem;
    }
    .svc-table tbody tr { transition: background 0.15s; }
    .svc-table tbody tr:nth-child(even) { background: #fafbfc; }
    .svc-table tbody tr:hover { background: #fff7ed; }
    .svc-thumb {
        width: 48px; height: 48px;
        border-radius: 10px; object-fit: cover;
        border: 2px solid #f3f4f6;
    }
    .svc-thumb-placeholder {
        width: 48px; height: 48px;
        border-radius: 10px; background: #f3f4f6;
        display: flex; align-items: center; justify-content: center; color: #d1d5db;
    }
    .btn-action {
        width: 34px; height: 34px;
        border-radius: 8px; display: inline-flex;
        align-items: center; justify-content: center;
        font-size: 0.85rem; transition: all 0.2s;
        border: 1px solid; background: transparent; cursor: pointer;
    }
    .btn-action-edit { color: #f59e0b; border-color: #fde68a; }
    .btn-action-edit:hover { background: #f59e0b; color: #fff; border-color: #f59e0b; }
    .btn-action-delete { color: #ef4444; border-color: #fecaca; }
    .btn-action-delete:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
    .badge-status {
        border-radius: 20px; padding: 5px 12px; font-weight: 600; font-size: 0.78rem;
    }
    .badge-active { background: #d1fae5; color: #065f46; }
    .badge-inactive { background: #fee2e2; color: #991b1b; }
    .price-cell { font-weight: 700; color: #FF6B35; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Quản lý dịch vụ sửa chữa</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">@Model.Count dịch vụ trong hệ thống</p>
    </div>
    <a asp-area="Admin" asp-controller="RepairService" asp-action="Create"
       class="btn btn-primary d-flex align-items-center gap-2"
       style="background:#FF6B35;border-color:#FF6B35;border-radius:10px;padding:10px 20px;font-weight:600;">
        <i class="fas fa-plus"></i> Thêm dịch vụ
    </a>
</div>

<div class="card" style="border-radius:14px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table svc-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Hình</th>
                        <th>Tên dịch vụ</th>
                        <th>Giá</th>
                        <th>Thời gian dự kiến</th>
                        <th>Trạng thái</th>
                        <th>Lịch đặt</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><strong class="text-muted">@s.Id</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.ImageUrl))
                                {
                                    <img src="@s.ImageUrl" alt="@s.Name" class="svc-thumb"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="svc-thumb-placeholder" style="display:none;">
                                        <i class="fas fa-wrench"></i>
                                    </div>
                                }
                                else
                                {
                                    <div class="svc-thumb-placeholder">
                                        <i class="fas fa-wrench"></i>
                                    </div>
                                }
                            </td>
                            <td><strong>@s.Name</strong></td>
                            <td class="price-cell">@s.Price.ToString("N0") đ</td>
                            <td class="text-muted">@(string.IsNullOrEmpty(s.EstimatedTime) ? "-" : s.EstimatedTime)</td>
                            <td>
                                @if (s.IsActive)
                                {
                                    <span class="badge-status badge-active"><i class="fas fa-check-circle me-1"></i>Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive"><i class="fas fa-times-circle me-1"></i>Tạm tắt</span>
                                }
                            </td>
                            <td>
                                <span class="badge" style="background:#e0f2fe;color:#0284c7;border-radius:20px;padding:5px 12px;font-weight:600;">
                                    @s.RepairBookings.Count lịch
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-area="Admin" asp-controller="RepairService" asp-action="Edit" asp-route-id="@s.Id"
                                       class="btn-action btn-action-edit" title="Chỉnh sửa">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <form asp-area="Admin" asp-controller="RepairService" asp-action="Delete" asp-route-id="@s.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa dịch vụ này? Nếu có lịch đặt, dịch vụ sẽ chuyển sang trạng thái tạm tắt.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action btn-action-delete" title="Xóa">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fas fa-wrench fa-2x mb-2 d-block" style="opacity:0.3;"></i>
                                Chưa có dịch vụ nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
