@model List<Review>
@{
    ViewData["Title"] = "Quản lý đánh giá";
}

@section Styles {
<style>
    .rev-table th {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6b7280;
        font-weight: 600;
        border-bottom: 2px solid #f3f4f6;
        padding: 14px 16px;
        white-space: nowrap;
    }
    .rev-table td {
        vertical-align: middle;
        padding: 12px 16px;
        font-size: 0.88rem;
    }
    .rev-table tbody tr { transition: background 0.15s; }
    .rev-table tbody tr:nth-child(even) { background: #fafbfc; }
    .rev-table tbody tr:hover { background: #fff7ed; }
    .stars { color: #f59e0b; letter-spacing: 1px; font-size: 0.95rem; }
    .stars .empty { color: #e5e7eb; }
    .comment-cell {
        max-width: 360px;
        white-space: normal;
        line-height: 1.4;
        color: #374151;
    }
    .btn-action {
        width: 34px; height: 34px;
        border-radius: 8px; display: inline-flex;
        align-items: center; justify-content: center;
        font-size: 0.85rem; transition: all 0.2s;
        border: 1px solid; background: transparent; cursor: pointer;
    }
    .btn-action-delete { color: #ef4444; border-color: #fecaca; }
    .btn-action-delete:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
    .product-link { color: #1f2937; font-weight: 600; text-decoration: none; }
    .product-link:hover { color: #FF6B35; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1" style="color:#1f2937;">Quản lý đánh giá</h5>
        <p class="text-muted mb-0" style="font-size:0.85rem;">@Model.Count đánh giá từ khách hàng</p>
    </div>
</div>

<div class="card" style="border-radius:14px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table rev-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Khách hàng</th>
                        <th>Sản phẩm</th>
                        <th>Đánh giá</th>
                        <th>Bình luận</th>
                        <th>Ngày</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td><strong class="text-muted">@r.Id</strong></td>
                            <td>
                                <div class="fw-semibold">@(r.User?.FullName ?? "(Không rõ)")</div>
                                <div class="text-muted" style="font-size:0.78rem;">@(r.User?.Email ?? "-")</div>
                            </td>
                            <td>
                                <span class="product-link">@(r.Product?.Name ?? "(Sản phẩm đã xóa)")</span>
                            </td>
                            <td>
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= r.Rating)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-star empty"></i>
                                        }
                                    }
                                    <span class="text-muted ms-2" style="font-size:0.8rem;">(@r.Rating/5)</span>
                                </div>
                            </td>
                            <td class="comment-cell">
                                @if (!string.IsNullOrEmpty(r.Comment))
                                {
                                    @r.Comment
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">(Không có bình luận)</span>
                                }
                            </td>
                            <td class="text-muted" style="white-space:nowrap;">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <form asp-area="Admin" asp-controller="Review" asp-action="Delete" asp-route-id="@r.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa đánh giá này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action btn-action-delete" title="Xóa">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="fas fa-star fa-2x mb-2 d-block" style="opacity:0.3;"></i>
                                Chưa có đánh giá nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
