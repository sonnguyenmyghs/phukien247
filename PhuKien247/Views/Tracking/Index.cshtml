@{
    ViewData["Title"] = "Tra cứu đơn hàng";
    var order = ViewBag.Order as Order;
    var error = ViewBag.Error as string;
    var orderId = ViewBag.OrderId as int? ?? 0;
    var phoneNumber = ViewBag.PhoneNumber as string;

    string OrderStatusText(OrderStatus s) => s switch
    {
        OrderStatus.ChoXacNhan => "Chờ xác nhận",
        OrderStatus.DaXacNhan => "Đã xác nhận",
        OrderStatus.DangGiao => "Đang giao",
        OrderStatus.HoanThanh => "Hoàn thành",
        OrderStatus.DaHuy => "Đã hủy",
        _ => s.ToString()
    };

    string OrderStatusBadge(OrderStatus s) => s switch
    {
        OrderStatus.ChoXacNhan => "bg-warning text-dark",
        OrderStatus.DaXacNhan => "bg-info",
        OrderStatus.DangGiao => "bg-primary",
        OrderStatus.HoanThanh => "bg-success",
        OrderStatus.DaHuy => "bg-danger",
        _ => "bg-secondary"
    };
}

@section Styles {
<style>
    .tracking-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        padding: 3rem 0 2rem;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .tracking-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: rgba(255,107,53,0.08);
    }
    .tracking-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        padding: 2rem;
        margin-top: -2rem;
        position: relative;
        z-index: 2;
    }
    .tracking-form input {
        border-radius: 10px;
        padding: 0.7rem 1rem;
        border: 1.5px solid #e5e7eb;
        font-size: 0.95rem;
        transition: all 0.3s;
    }
    .tracking-form input:focus {
        border-color: #FF6B35;
        box-shadow: 0 0 0 3px rgba(255,107,53,0.12);
    }
    .btn-track {
        background: linear-gradient(135deg, #FF6B35, #e55a26);
        color: #fff;
        border: none;
        padding: 0.7rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
    }
    .btn-track:hover {
        box-shadow: 0 6px 20px rgba(255,107,53,0.35);
        transform: translateY(-2px);
        color: #fff;
    }
    .timeline {
        display: flex;
        justify-content: space-between;
        margin: 2rem 0;
        position: relative;
    }
    .timeline::before {
        content: '';
        position: absolute;
        top: 22px;
        left: 0;
        right: 0;
        height: 3px;
        background: #e5e7eb;
        z-index: 0;
    }
    .timeline-step {
        flex: 1;
        text-align: center;
        position: relative;
        z-index: 1;
    }
    .timeline-step .step-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #e5e7eb;
        color: #9ca3af;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.5rem;
        font-size: 1rem;
        transition: all 0.3s;
    }
    .timeline-step.active .step-icon {
        background: linear-gradient(135deg, #FF6B35, #e55a26);
        color: #fff;
        box-shadow: 0 4px 12px rgba(255,107,53,0.35);
    }
    .timeline-step.cancelled .step-icon {
        background: #ef4444;
        color: #fff;
    }
    .timeline-step .step-label {
        font-size: 0.82rem;
        color: #6b7280;
        font-weight: 500;
    }
    .timeline-step.active .step-label {
        color: #1f2937;
        font-weight: 600;
    }
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.6rem 0;
        border-bottom: 1px solid #f3f4f6;
    }
    .info-row:last-child {
        border-bottom: none;
    }
    .info-row .label {
        color: #6b7280;
        font-size: 0.88rem;
    }
    .info-row .value {
        font-weight: 600;
        color: #1f2937;
    }
</style>
}

<section class="tracking-hero">
    <div class="container text-center">
        <h1 class="fw-bold"><i class="fas fa-search-location me-2"></i>Tra cứu đơn hàng</h1>
        <p class="mb-0" style="color:rgba(255,255,255,0.75);">Nhập mã đơn hàng và số điện thoại để theo dõi trạng thái</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="tracking-card">
                <form method="post" asp-action="Index" class="tracking-form">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold"><i class="fas fa-hashtag me-1" style="color:#FF6B35;"></i>Mã đơn hàng</label>
                            <input type="number" name="orderId" value="@(orderId > 0 ? orderId.ToString() : "")" class="form-control" placeholder="Ví dụ: 123" required />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold"><i class="fas fa-phone me-1" style="color:#FF6B35;"></i>Số điện thoại</label>
                            <input type="text" name="phoneNumber" value="@phoneNumber" class="form-control" placeholder="Số điện thoại đặt hàng" required />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn-track w-100">
                                <i class="fas fa-search me-1"></i>Tra cứu
                            </button>
                        </div>
                    </div>
                </form>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger mt-4 mb-0" style="border-radius:10px;">
                        <i class="fas fa-exclamation-circle me-1"></i>@error
                    </div>
                }
            </div>

            @if (order != null)
            {
                var isCancelled = order.Status == OrderStatus.DaHuy;
                var step = (int)order.Status;

                <div class="tracking-card mt-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap mb-3">
                        <div>
                            <h4 class="fw-bold mb-1">Đơn hàng #@order.Id</h4>
                            <p class="text-muted mb-0" style="font-size:0.88rem;">
                                <i class="far fa-clock me-1"></i>Đặt ngày @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </p>
                        </div>
                        <span class="badge @OrderStatusBadge(order.Status)" style="font-size:0.9rem;padding:0.5rem 1rem;border-radius:20px;">
                            @OrderStatusText(order.Status)
                        </span>
                    </div>

                    <!-- Status Timeline -->
                    @if (!isCancelled)
                    {
                        <div class="timeline">
                            <div class="timeline-step @(step >= 0 ? "active" : "")">
                                <div class="step-icon"><i class="fas fa-clock"></i></div>
                                <div class="step-label">Chờ xác nhận</div>
                            </div>
                            <div class="timeline-step @(step >= 1 ? "active" : "")">
                                <div class="step-icon"><i class="fas fa-check"></i></div>
                                <div class="step-label">Đã xác nhận</div>
                            </div>
                            <div class="timeline-step @(step >= 2 ? "active" : "")">
                                <div class="step-icon"><i class="fas fa-truck"></i></div>
                                <div class="step-label">Đang giao</div>
                            </div>
                            <div class="timeline-step @(step >= 3 ? "active" : "")">
                                <div class="step-icon"><i class="fas fa-check-double"></i></div>
                                <div class="step-label">Hoàn thành</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger" style="border-radius:10px;">
                            <i class="fas fa-times-circle me-1"></i>Đơn hàng này đã bị hủy.
                        </div>
                    }

                    <!-- Customer Info -->
                    <h6 class="fw-bold mt-4 mb-3"><i class="fas fa-user me-1" style="color:#FF6B35;"></i>Thông tin giao hàng</h6>
                    <div class="info-row">
                        <span class="label">Khách hàng</span>
                        <span class="value">@order.User?.FullName</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Số điện thoại</span>
                        <span class="value">@order.PhoneNumber</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Địa chỉ</span>
                        <span class="value text-end" style="max-width:60%;">@order.ShippingAddress</span>
                    </div>
                    <div class="info-row">
                        <span class="label">Phương thức thanh toán</span>
                        <span class="value">@(order.PaymentMethod == PaymentMethod.COD ? "Thanh toán khi nhận hàng (COD)" : "Chuyển khoản")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(order.Note))
                    {
                        <div class="info-row">
                            <span class="label">Ghi chú</span>
                            <span class="value text-end" style="max-width:60%;">@order.Note</span>
                        </div>
                    }

                    <!-- Items -->
                    <h6 class="fw-bold mt-4 mb-3"><i class="fas fa-box me-1" style="color:#FF6B35;"></i>Sản phẩm đã đặt</h6>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr style="background:#fafbfc;">
                                    <th>Sản phẩm</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in order.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                                {
                                                    <img src="@item.Product.ImageUrl" style="width:42px;height:42px;border-radius:8px;object-fit:cover;" />
                                                }
                                                <strong>@item.Product?.Name</strong>
                                            </div>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                        <td class="text-end fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0")) đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                    <td class="text-end fw-bold" style="color:#FF6B35;font-size:1.1rem;">@order.TotalAmount.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }

            <div class="text-center mt-4">
                <a asp-controller="Tracking" asp-action="RepairLookup" class="text-decoration-none" style="color:#FF6B35;font-weight:600;">
                    <i class="fas fa-tools me-1"></i>Tra cứu lịch sửa chữa
                </a>
            </div>
        </div>
    </div>
</div>
