@model List<CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-cart-arrow-down fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Giỏ hàng trống</h4>
            <p class="text-muted">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-pk mt-2">
                <i class="fas fa-shopping-bag me-1"></i>Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px;">Hình ảnh</th>
                        <th>Sản phẩm</th>
                        <th class="text-end">Đơn giá</th>
                        <th style="width: 180px;" class="text-center">Số lượng</th>
                        <th class="text-end">Thành tiền</th>
                        <th style="width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center rounded" style="width: 60px; height: 60px;">
                                        <i class="fas fa-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <strong>@item.ProductName</strong>
                            </td>
                            <td class="text-end">@item.Price.ToString("N0") đ</td>
                            <td>
                                <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" class="form-control form-control-sm text-center" style="width: 70px;" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Cập nhật">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="text-end fw-bold">@item.Total.ToString("N0") đ</td>
                            <td class="text-center">
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <a asp-controller="Product" asp-action="Index" class="btn btn-pk-outline">
                    <i class="fas fa-arrow-left me-1"></i>Tiếp tục mua sắm
                </a>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Tổng cộng:</h5>
                            <h4 class="mb-0 text-danger fw-bold">@Model.Sum(x => x.Total).ToString("N0") đ</h4>
                        </div>
                        <a asp-controller="Order" asp-action="Checkout" class="btn btn-pk w-100">
                            <i class="fas fa-credit-card me-1"></i>Thanh toán
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
