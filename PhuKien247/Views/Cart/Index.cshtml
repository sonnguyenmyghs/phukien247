@model List<CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

@section Styles {
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet" />
    <style>
        .cart-page {
            background: #f5f5f7;
            min-height: calc(100vh - 200px);
            padding: 2rem 0 3rem;
        }
        .cart-header {
            margin-bottom: 2rem;
        }
        .cart-header h2 {
            font-weight: 800;
            color: #1a1a2e;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .cart-header h2 .header-icon {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            background: linear-gradient(135deg, #FF6B35, #ff9a6c);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.2rem;
        }
        .cart-badge {
            background: #FF6B35;
            color: #fff;
            border-radius: 20px;
            padding: 0.15rem 0.7rem;
            font-size: 0.85rem;
            font-weight: 600;
            margin-left: 0.5rem;
        }

        /* Cart Items */
        .cart-item-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            padding: 1.25rem;
            margin-bottom: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
            border: 1px solid #f0f0f0;
        }
        .cart-item-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        .cart-item-img {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            object-fit: cover;
            border: 1px solid #f0f0f0;
        }
        .cart-item-img-placeholder {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #f0f0f0;
        }
        .cart-item-img-placeholder svg {
            width: 32px;
            height: 32px;
            opacity: 0.3;
        }
        .cart-item-name {
            font-weight: 600;
            color: #1a1a2e;
            text-decoration: none;
            transition: color 0.2s;
            font-size: 1rem;
        }
        .cart-item-name:hover {
            color: #FF6B35;
        }
        .cart-item-price {
            color: #888;
            font-size: 0.9rem;
        }

        /* Quantity stepper */
        .qty-stepper {
            display: inline-flex;
            align-items: center;
            border: 1.5px solid #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
        }
        .qty-stepper .qty-btn {
            width: 36px;
            height: 36px;
            border: none;
            background: #f8f9fa;
            color: #555;
            font-size: 1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s, color 0.2s;
        }
        .qty-stepper .qty-btn:hover {
            background: #FF6B35;
            color: #fff;
        }
        .qty-stepper .qty-input {
            width: 48px;
            height: 36px;
            border: none;
            text-align: center;
            font-weight: 600;
            font-size: 0.95rem;
            color: #1a1a2e;
            -moz-appearance: textfield;
        }
        .qty-stepper .qty-input::-webkit-outer-spin-button,
        .qty-stepper .qty-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .cart-item-total {
            font-weight: 700;
            color: #FF6B35;
            font-size: 1.05rem;
        }
        .btn-remove {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            border: 1.5px solid #fee2e2;
            background: #fff5f5;
            color: #ef4444;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            cursor: pointer;
        }
        .btn-remove:hover {
            background: #ef4444;
            color: #fff;
            border-color: #ef4444;
        }

        /* Summary Card */
        .cart-summary {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            padding: 1.5rem;
            border: 1px solid #f0f0f0;
        }
        .cart-summary h5 {
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid #f0f0f0;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 0;
        }
        .summary-row.total {
            border-top: 2px dashed #e0e0e0;
            margin-top: 0.75rem;
            padding-top: 1rem;
        }
        .summary-row.total .label {
            font-weight: 700;
            font-size: 1.05rem;
        }
        .summary-row.total .value {
            font-weight: 800;
            font-size: 1.4rem;
            color: #FF6B35;
        }
        .btn-checkout {
            background: linear-gradient(135deg, #FF6B35, #e55a26);
            border: none;
            border-radius: 12px;
            padding: 0.85rem;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            transition: transform 0.2s, box-shadow 0.2s;
            letter-spacing: 0.3px;
        }
        .btn-checkout:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,107,53,0.35);
            color: #fff;
        }
        .btn-continue {
            border: 1.5px solid #FF6B35;
            color: #FF6B35;
            border-radius: 12px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            transition: all 0.2s;
            background: transparent;
        }
        .btn-continue:hover {
            background: #FF6B35;
            color: #fff;
        }

        /* Empty cart */
        .empty-cart {
            text-align: center;
            padding: 4rem 2rem;
        }
        .empty-cart-icon {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #fff5f0, #ffe8dc);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
        }
        .empty-cart-icon svg {
            width: 56px;
            height: 56px;
        }
        .empty-cart h4 {
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 0.5rem;
        }
        .empty-cart p {
            color: #888;
            font-size: 1.05rem;
            margin-bottom: 1.5rem;
        }
        .btn-shop-now {
            background: linear-gradient(135deg, #FF6B35, #e55a26);
            border: none;
            border-radius: 12px;
            padding: 0.75rem 2rem;
            font-size: 1.05rem;
            font-weight: 600;
            color: #fff;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-shop-now:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,107,53,0.35);
            color: #fff;
        }

        @@media (max-width: 991.98px) {
            .cart-summary-wrap {
                position: static !important;
            }
        }
    </style>
}

<section class="cart-page">
    <div class="container">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-cart" data-aos="fade-up">
                <div class="empty-cart-icon">
                    <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20 20h28l-4 20H24L20 20z" stroke="#FF6B35" stroke-width="2.5" fill="none"/>
                        <path d="M16 16h4" stroke="#FF6B35" stroke-width="2.5" stroke-linecap="round"/>
                        <circle cx="26" cy="48" r="3" fill="#FF6B35"/>
                        <circle cx="42" cy="48" r="3" fill="#FF6B35"/>
                        <path d="M30 32h4M32 30v4" stroke="#ffb088" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <h4>Giỏ hàng trống</h4>
                <p>Bạn chưa có sản phẩm nào trong giỏ hàng.<br/>Hãy khám phá các sản phẩm tuyệt vời của chúng tôi!</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-shop-now">
                    <i class="fas fa-shopping-bag me-2"></i>Tiếp tục mua sắm
                </a>
            </div>
        }
        else
        {
            <div class="cart-header" data-aos="fade-down">
                <h2>
                    <span class="header-icon"><i class="fas fa-shopping-cart"></i></span>
                    Giỏ hàng của bạn
                    <span class="cart-badge">@Model.Count sản phẩm</span>
                </h2>
            </div>

            <div class="row g-4">
                <!-- Cart Items -->
                <div class="col-lg-8">
                    @for (int cartIdx = 0; cartIdx < Model.Count; cartIdx++)
                    {
                        var item = Model[cartIdx];
                        <div class="cart-item-card" data-aos="fade-up" data-aos-delay="@(cartIdx * 80)">
                            <div class="row align-items-center g-3">
                                <!-- Image -->
                                <div class="col-auto">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.ProductName" class="cart-item-img" />
                                    }
                                    else
                                    {
                                        <div class="cart-item-img-placeholder">
                                            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <rect x="4" y="8" width="40" height="32" rx="4" stroke="#ccc" stroke-width="2"/>
                                                <circle cx="16" cy="20" r="4" stroke="#ccc" stroke-width="2"/>
                                                <path d="M4 32l12-10 8 6 8-6 12 10" stroke="#ccc" stroke-width="2"/>
                                            </svg>
                                        </div>
                                    }
                                </div>

                                <!-- Name & Price -->
                                <div class="col">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId" class="cart-item-name d-block mb-1">@item.ProductName</a>
                                    <span class="cart-item-price">@item.Price.ToString("N0") đ</span>
                                </div>

                                <!-- Quantity Stepper -->
                                <div class="col-auto">
                                    <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-inline qty-form">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <div class="qty-stepper">
                                            <button type="button" class="qty-btn qty-minus" aria-label="Giảm số lượng">
                                                <i class="fas fa-minus" style="font-size:0.7rem;"></i>
                                            </button>
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" class="qty-input" />
                                            <button type="button" class="qty-btn qty-plus" aria-label="Tăng số lượng">
                                                <i class="fas fa-plus" style="font-size:0.7rem;"></i>
                                            </button>
                                        </div>
                                    </form>
                                </div>

                                <!-- Line Total -->
                                <div class="col-auto text-end" style="min-width: 110px;">
                                    <span class="cart-item-total">@item.Total.ToString("N0") đ</span>
                                </div>

                                <!-- Remove -->
                                <div class="col-auto">
                                    <form asp-controller="Cart" asp-action="Remove" method="post" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn-remove" title="Xóa sản phẩm">
                                            <i class="fas fa-trash-alt" style="font-size:0.85rem;"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mt-3" data-aos="fade-up">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-continue">
                            <i class="fas fa-arrow-left me-2"></i>Tiếp tục mua sắm
                        </a>
                    </div>
                </div>

                <!-- Cart Summary -->
                <div class="col-lg-4">
                    <div class="cart-summary-wrap" style="position: sticky; top: 90px;" data-aos="fade-left" data-aos-delay="200">
                        <div class="cart-summary">
                            <h5><i class="fas fa-receipt me-2"></i>Tóm tắt đơn hàng</h5>

                            <div class="summary-row">
                                <span style="color:#666;">Tạm tính (@Model.Count sản phẩm)</span>
                                <span class="fw-semibold">@Model.Sum(x => x.Total).ToString("N0") đ</span>
                            </div>
                            <div class="summary-row">
                                <span style="color:#666;">Phí vận chuyển</span>
                                <span class="fw-semibold" style="color:#22c55e;">Miễn phí</span>
                            </div>

                            <div class="summary-row total">
                                <span class="label">Tổng cộng</span>
                                <span class="value">@Model.Sum(x => x.Total).ToString("N0") đ</span>
                            </div>

                            <div class="d-grid mt-4">
                                <a asp-controller="Order" asp-action="Checkout" class="btn btn-checkout">
                                    <i class="fas fa-credit-card me-2"></i>Thanh toán
                                </a>
                            </div>

                            <div class="text-center mt-3">
                                <small style="color:#999;">
                                    <i class="fas fa-shield-alt me-1"></i>Thanh toán an toàn & bảo mật
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ once: true });

        // Quantity stepper logic
        document.querySelectorAll('.qty-stepper').forEach(function(stepper) {
            var input = stepper.querySelector('.qty-input');
            var form = stepper.closest('form');

            stepper.querySelector('.qty-minus').addEventListener('click', function() {
                var val = parseInt(input.value) || 1;
                if (val > 1) {
                    input.value = val - 1;
                    form.submit();
                }
            });

            stepper.querySelector('.qty-plus').addEventListener('click', function() {
                var val = parseInt(input.value) || 1;
                if (val < 99) {
                    input.value = val + 1;
                    form.submit();
                }
            });

            input.addEventListener('change', function() {
                var val = parseInt(input.value) || 1;
                if (val < 1) input.value = 1;
                if (val > 99) input.value = 99;
                form.submit();
            });
        });
    </script>
}
