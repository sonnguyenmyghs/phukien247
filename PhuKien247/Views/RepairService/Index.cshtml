@model List<RepairService>
@{
    ViewData["Title"] = "Dịch vụ sửa chữa";
}

<div class="container">
    <div class="text-center mb-4">
        <h2>Dịch vụ sửa chữa</h2>
        <p class="text-muted">Đội ngũ kỹ thuật viên chuyên nghiệp, sửa chữa nhanh chóng và uy tín</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">Hiện tại chưa có dịch vụ nào.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var service in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(service.ImageUrl))
                        {
                            <img src="@service.ImageUrl" class="card-img-top" alt="@service.Name"
                                 style="height: 200px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height: 200px;">
                                <i class="bi bi-tools fs-1 text-muted"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@service.Name</h5>
                            @if (!string.IsNullOrEmpty(service.Description))
                            {
                                <p class="card-text text-muted">@service.Description</p>
                            }
                            <div class="mt-auto">
                                <p class="mb-1">
                                    <strong class="text-danger fs-5">@service.Price.ToString("N0") đ</strong>
                                </p>
                                @if (!string.IsNullOrEmpty(service.EstimatedTime))
                                {
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-clock"></i> Thời gian ước tính: @service.EstimatedTime
                                    </p>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <a asp-controller="RepairService" asp-action="Book" asp-route-serviceId="@service.Id"
                               class="btn btn-primary w-100">
                                <i class="bi bi-calendar-check"></i> Đặt lịch
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
