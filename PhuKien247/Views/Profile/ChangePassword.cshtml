@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

@section Styles {
<style>
    .pwd-wrapper { padding: 60px 0; background: linear-gradient(135deg, #fff7f3 0%, #ffe8db 100%); min-height: 80vh; }
    .pwd-card { background: #fff; border-radius: 18px; box-shadow: 0 8px 30px rgba(0,0,0,0.08); padding: 40px; max-width: 540px; margin: 0 auto; }
    .pwd-icon {
        width: 70px; height: 70px; border-radius: 50%;
        background: linear-gradient(135deg, #FF6B35, #f7971e); color: #fff;
        margin: 0 auto 18px; display: flex; align-items: center; justify-content: center; font-size: 1.6rem;
    }
    .form-control:focus { border-color: #FF6B35; box-shadow: 0 0 0 0.2rem rgba(255,107,53,.15); }
    .btn-pk-save {
        background: linear-gradient(135deg, #FF6B35, #f7971e); color: #fff;
        border: none; padding: 10px 28px; border-radius: 10px; font-weight: 600;
    }
    .btn-pk-save:hover { transform: translateY(-2px); color:#fff; }
</style>
}

<section class="pwd-wrapper">
    <div class="container">
        <div class="pwd-card">
            <div class="pwd-icon"><i class="fas fa-key"></i></div>
            <h4 class="text-center fw-bold mb-2">Đổi mật khẩu</h4>
            <p class="text-center text-muted mb-4">Hãy chọn mật khẩu mạnh và không sử dụng cho các tài khoản khác.</p>

            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label fw-semibold"></label>
                    <input asp-for="OldPassword" class="form-control" />
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn-pk-save flex-grow-1">
                        <i class="fas fa-save me-1"></i>Cập nhật
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
