@{
    ViewData["Title"] = "Liên hệ";
}

@section Styles {
<style>
    .contact-hero {
        background: linear-gradient(135deg, #FF6B35 0%, #f7971e 100%);
        color: #fff; padding: 70px 0 90px; text-align: center; position: relative; overflow: hidden;
    }
    .contact-hero::after {
        content: ''; position: absolute; bottom: -1px; left: 0; width: 100%; height: 60px;
        background: #fff; clip-path: polygon(0 100%, 100% 100%, 100% 0);
    }
    .contact-hero h1 { font-size: 2.6rem; font-weight: 800; margin-bottom: 8px; }
    .contact-hero p { opacity: 0.9; font-size: 1.05rem; }
    .contact-section { padding: 70px 0; }
    .contact-card {
        background: #fff; border-radius: 18px; box-shadow: 0 8px 30px rgba(0,0,0,0.06);
        padding: 35px; height: 100%;
    }
    .contact-info-item {
        display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid #f3f4f6;
    }
    .contact-info-item:last-child { border-bottom: none; }
    .contact-info-icon {
        width: 50px; height: 50px; border-radius: 12px; flex-shrink: 0;
        background: linear-gradient(135deg, #FF6B35, #f7971e); color: #fff;
        display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    }
    .contact-info-item h6 { margin: 0 0 4px; font-weight: 700; color: #1f2937; }
    .contact-info-item p { margin: 0; color: #6b7280; font-size: 0.92rem; }
    .form-control:focus { border-color: #FF6B35; box-shadow: 0 0 0 0.2rem rgba(255,107,53,.15); }
    .btn-pk-submit {
        background: linear-gradient(135deg, #FF6B35, #f7971e); color: #fff; border: none;
        padding: 12px 30px; border-radius: 10px; font-weight: 600; transition: all 0.3s;
    }
    .btn-pk-submit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,107,53,0.3); color:#fff; }
    .map-frame { border-radius: 18px; overflow: hidden; box-shadow: 0 8px 30px rgba(0,0,0,0.08); margin-top: 40px; }
    .map-frame iframe { width: 100%; height: 360px; border: 0; display: block; }
</style>
}

<section class="contact-hero">
    <div class="container">
        <h1><i class="fas fa-headset me-2"></i>Liên hệ với chúng tôi</h1>
        <p>Chúng tôi luôn sẵn sàng hỗ trợ bạn 24/7</p>
    </div>
</section>

<section class="contact-section">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-5" data-aos="fade-right">
                <div class="contact-card">
                    <h4 class="fw-bold mb-3" style="color:#FF6B35;"><i class="fas fa-map-pin me-2"></i>Thông tin cửa hàng</h4>
                    <p class="text-muted mb-4">Hãy ghé thăm hoặc liên hệ với chúng tôi qua các kênh sau:</p>

                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <h6>Địa chỉ</h6>
                            <p>123 Nguyễn Trãi, Phường Bến Thành, Quận 1, TP.HCM</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fas fa-phone"></i></div>
                        <div>
                            <h6>Hotline</h6>
                            <p>0123 456 789 - 0987 654 321</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fas fa-envelope"></i></div>
                        <div>
                            <h6>Email</h6>
                            <p>info@phukien247.vn</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="fas fa-clock"></i></div>
                        <div>
                            <h6>Giờ mở cửa</h6>
                            <p>Thứ 2 - Chủ Nhật: 8:00 - 21:00</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7" data-aos="fade-left">
                <div class="contact-card">
                    <h4 class="fw-bold mb-3" style="color:#FF6B35;"><i class="fas fa-paper-plane me-2"></i>Gửi tin nhắn cho chúng tôi</h4>
                    <p class="text-muted mb-4">Điền thông tin và chúng tôi sẽ phản hồi trong vòng 24 giờ.</p>

                    <form method="post" asp-action="Contact">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                                <input name="name" type="text" class="form-control" required placeholder="Nguyễn Văn A" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                <input name="email" type="email" class="form-control" required placeholder="email@example.com" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Số điện thoại</label>
                                <input name="phone" type="tel" class="form-control" placeholder="0901234567" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Nội dung <span class="text-danger">*</span></label>
                                <textarea name="message" rows="5" class="form-control" required placeholder="Hãy chia sẻ với chúng tôi..."></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn-pk-submit">
                                    <i class="fas fa-paper-plane me-1"></i>Gửi tin nhắn
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="map-frame">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4036983889994!2d106.69533261533415!3d10.776530992321373!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f3ec1bcd5db%3A0xbf78d39e7a2f1efa!2zTmd1eeG7hW4gVHLDo2ksIFBoxrDhu51uZyBC4bq_biBUaMOgbmgsIFF14bqtbiAxLCBI4buTIENow60gTWluaA!5e0!3m2!1svi!2s!4v1700000000000"
                allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </div>
</section>
