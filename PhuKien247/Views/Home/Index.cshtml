@{
    ViewData["Title"] = "Trang chủ";

    var featuredProducts = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var repairServices = ViewBag.RepairServices as List<RepairService> ?? new List<RepairService>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();

    // Category icon mapping
    var categoryIcons = new Dictionary<string, string>
    {
        { "default", "fas fa-th-large" },
        { "ốp lưng", "fas fa-shield-alt" },
        { "case", "fas fa-shield-alt" },
        { "sạc", "fas fa-bolt" },
        { "charger", "fas fa-bolt" },
        { "tai nghe", "fas fa-headphones" },
        { "headphone", "fas fa-headphones" },
        { "cáp", "fas fa-plug" },
        { "cable", "fas fa-plug" },
        { "pin", "fas fa-battery-full" },
        { "battery", "fas fa-battery-full" },
        { "kính", "fas fa-mobile-screen" },
        { "screen", "fas fa-mobile-screen" },
        { "loa", "fas fa-volume-up" },
        { "speaker", "fas fa-volume-up" },
        { "phụ kiện", "fas fa-puzzle-piece" },
        { "accessory", "fas fa-puzzle-piece" },
        { "bàn phím", "fas fa-keyboard" },
        { "chuột", "fas fa-computer-mouse" },
        { "đồng hồ", "fas fa-clock" },
        { "watch", "fas fa-clock" },
    };

    string GetCategoryIcon(string categoryName)
    {
        if (string.IsNullOrEmpty(categoryName)) return categoryIcons["default"];
        var lower = categoryName.ToLower();
        foreach (var kvp in categoryIcons)
        {
            if (kvp.Key != "default" && lower.Contains(kvp.Key))
                return kvp.Value;
        }
        return categoryIcons["default"];
    }

    // Category color palette
    var categoryColors = new[] {
        "linear-gradient(135deg, #FF6B35, #ff8f65)",
        "linear-gradient(135deg, #6C63FF, #8b85ff)",
        "linear-gradient(135deg, #00C9A7, #33d6bc)",
        "linear-gradient(135deg, #FF5E78, #ff8a9b)",
        "linear-gradient(135deg, #FFB347, #ffc870)",
        "linear-gradient(135deg, #4ECDC4, #7eddd6)",
        "linear-gradient(135deg, #A855F7, #c084fc)",
        "linear-gradient(135deg, #3B82F6, #60a5fa)",
    };
}

