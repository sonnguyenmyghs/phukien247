                                    <div class="mt-auto">
                                        <div class="mb-2">
                                            @if (product.SalePrice.HasValue && product.SalePrice < product.Price)
                                            {
                                                <span class="price-current">@product.SalePrice.Value.ToString("N0")&#273;</span>
                                                <span class="price-original ms-2">@product.Price.ToString("N0")&#273;</span>
                                            }
                                            else
                                            {
                                                <span class="price-current">@product.Price.ToString("N0")&#273;</span>
                                            }
                                        </div>
                                        <button class="btn-add-cart" onclick="window.location.href='@Url.Action("Details", "Product", new { id = product.Id })'">
                                            <i class="fas fa-cart-plus me-1"></i>Th&ecirc;m v&agrave;o gi&#7887;
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
