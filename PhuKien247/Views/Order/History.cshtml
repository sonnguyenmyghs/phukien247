@model List<PhuKien247.Models.Order>

@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="fas fa-clipboard-list me-2"></i>Lịch sử đơn hàng</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">Chưa có đơn hàng</h4>
            <p class="text-muted">Bạn chưa có đơn hàng nào.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-pk mt-2">
                <i class="fas fa-shopping-bag me-1"></i>Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end fw-bold text-danger">@order.TotalAmount.ToString("N0") đ</td>
                            <td class="text-center">
                                @switch (order.Status)
                                {
                                    case PhuKien247.Models.OrderStatus.ChoXacNhan:
                                        <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                        break;
                                    case PhuKien247.Models.OrderStatus.DaXacNhan:
                                        <span class="badge bg-info text-dark">Đã xác nhận</span>
                                        break;
                                    case PhuKien247.Models.OrderStatus.DangGiao:
                                        <span class="badge bg-primary">Đang giao</span>
                                        break;
                                    case PhuKien247.Models.OrderStatus.HoanThanh:
                                        <span class="badge bg-success">Hoàn thành</span>
                                        break;
                                    case PhuKien247.Models.OrderStatus.DaHuy:
                                        <span class="badge bg-danger">Đã hủy</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Confirmation" asp-route-id="@order.Id" class="btn btn-sm btn-pk-outline">
                                    <i class="fas fa-eye me-1"></i>Xem
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
