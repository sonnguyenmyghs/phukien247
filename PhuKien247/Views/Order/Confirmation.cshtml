@model PhuKien247.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-4">
    <div class="text-center mb-4">
        <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
        <h2 class="text-success">Đặt hàng thành công!</h2>
        <p class="text-muted fs-5">Cảm ơn bạn đã mua hàng tại PhuKien247</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Mã đơn hàng:</div>
                        <div class="col-sm-8 fw-bold">#@Model.Id</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Ngày đặt:</div>
                        <div class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Địa chỉ giao hàng:</div>
                        <div class="col-sm-8">@Model.ShippingAddress</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Số điện thoại:</div>
                        <div class="col-sm-8">@Model.PhoneNumber</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Phương thức thanh toán:</div>
                        <div class="col-sm-8">
                            @if (Model.PaymentMethod == PhuKien247.Models.PaymentMethod.COD)
                            {
                                <span>Thanh toán khi nhận hàng (COD)</span>
                            }
                            else
                            {
                                <span>Chuyển khoản ngân hàng</span>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Ghi chú:</div>
                            <div class="col-sm-8">@Model.Note</div>
                        </div>
                    }
                    <div class="row mb-2">
                        <div class="col-sm-4 text-muted">Trạng thái:</div>
                        <div class="col-sm-8">
                            <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-box me-2"></i>Chi tiết sản phẩm</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>@detail.Product.Name</td>
                                        <td class="text-center">@detail.Quantity</td>
                                        <td class="text-end">@detail.UnitPrice.ToString("N0") đ</td>
                                        <td class="text-end fw-bold">@((detail.UnitPrice * detail.Quantity).ToString("N0")) đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                    <td class="text-end fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Product" asp-action="Index" class="btn btn-pk">
                    <i class="fas fa-shopping-bag me-1"></i>Tiếp tục mua sắm
                </a>
                <a asp-controller="Order" asp-action="History" class="btn btn-pk-outline">
                    <i class="fas fa-clipboard-list me-1"></i>Xem lịch sử đơn hàng
                </a>
            </div>
        </div>
    </div>
</div>
