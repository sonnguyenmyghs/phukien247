@model List<Product>
@{
    ViewData["Title"] = "Sản phẩm";

    var categories = ViewBag.Categories as List<Category>;
    var brands = ViewBag.Brands as List<Brand>;
    var currentSearch = ViewBag.CurrentSearch as string;
    int? currentCategoryId = ViewBag.CurrentCategoryId;
    int? currentBrandId = ViewBag.CurrentBrandId;
    var currentSort = ViewBag.CurrentSort as string;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalItems = ViewBag.TotalItems;
}

<div class="container-fluid">
    <!-- Search bar -->
    <div class="row mb-4">
        <div class="col-12">
            <form method="get" asp-action="Index" class="d-flex gap-2">
                <input type="text" name="search" value="@currentSearch" class="form-control"
                       placeholder="Tìm kiếm sản phẩm..." />
                @if (currentCategoryId.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@currentCategoryId" />
                }
                @if (currentBrandId.HasValue)
                {
                    <input type="hidden" name="brandId" value="@currentBrandId" />
                }
                @if (!string.IsNullOrEmpty(currentSort))
                {
                    <input type="hidden" name="sort" value="@currentSort" />
                }
                <button type="submit" class="btn btn-primary text-nowrap">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </form>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 col-md-4 mb-4">
            <!-- Category Filter -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <strong>Danh mục</strong>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">
                            <a href="@Url.Action("Index", new { search = currentSearch, brandId = currentBrandId, sort = currentSort })"
                               class="text-decoration-none @(currentCategoryId == null ? "fw-bold text-primary" : "text-dark")">
                                Tất cả danh mục
                            </a>
                        </li>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <li class="mb-1">
                                    <a href="@Url.Action("Index", new { search = currentSearch, categoryId = cat.Id, brandId = currentBrandId, sort = currentSort })"
                                       class="text-decoration-none @(currentCategoryId == cat.Id ? "fw-bold text-primary" : "text-dark")">
                                        @cat.Name
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <!-- Brand Filter -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <strong>Thương hiệu</strong>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">
                            <a href="@Url.Action("Index", new { search = currentSearch, categoryId = currentCategoryId, sort = currentSort })"
                               class="text-decoration-none @(currentBrandId == null ? "fw-bold text-primary" : "text-dark")">
                                Tất cả thương hiệu
                            </a>
                        </li>
                        @if (brands != null)
                        {
                            @foreach (var brand in brands)
                            {
                                <li class="mb-1">
                                    <a href="@Url.Action("Index", new { search = currentSearch, categoryId = currentCategoryId, brandId = brand.Id, sort = currentSort })"
                                       class="text-decoration-none @(currentBrandId == brand.Id ? "fw-bold text-primary" : "text-dark")">
                                        @brand.Name
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9 col-md-8">
            <!-- Sort & Result Info -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="mb-0 text-muted">Hiển thị <strong>@Model.Count</strong> / <strong>@totalItems</strong> sản phẩm</p>
                <div class="d-flex align-items-center gap-2">
                    <label class="text-nowrap mb-0">Sắp xếp:</label>
                    <select class="form-select form-select-sm" style="width: auto;" onchange="applySortFilter(this.value)">
                        <option value="newest" selected="@(currentSort == "newest" || currentSort == null)">Mới nhất</option>
                        <option value="price_asc" selected="@(currentSort == "price_asc")">Giá tăng dần</option>
                        <option value="price_desc" selected="@(currentSort == "price_desc")">Giá giảm dần</option>
                    </select>
                </div>
            </div>

            @if (Model.Count == 0)
            {
                <div class="alert alert-info text-center">
                    <p class="mb-0">Không tìm thấy sản phẩm nào phù hợp.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-3">
                    @foreach (var product in Model)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm">
                                <a href="@Url.Action("Details", "Product", new { id = product.Id })">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                                             style="height: 200px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center"
                                             style="height: 200px;">
                                            <span class="text-muted">Chưa có ảnh</span>
                                        </div>
                                    }
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title">
                                        <a href="@Url.Action("Details", "Product", new { id = product.Id })"
                                           class="text-decoration-none text-dark">
                                            @product.Name
                                        </a>
                                    </h6>
                                    <p class="text-muted small mb-1">@product.Category.Name &middot; @product.Brand.Name</p>
                                    <div class="mt-auto">
                                        @if (product.SalePrice.HasValue && product.SalePrice < product.Price)
                                        {
                                            <span class="text-decoration-line-through text-muted me-1">@product.Price.ToString("N0") đ</span>
                                            <span class="text-danger fw-bold">@product.SalePrice.Value.ToString("N0") đ</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">@product.Price.ToString("N0") đ</span>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer bg-white border-top-0">
                                    <a href="@Url.Action("Details", "Product", new { id = product.Id })"
                                       class="btn btn-outline-primary btn-sm w-100">
                                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <nav class="mt-4" aria-label="Phân trang">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { search = currentSearch, categoryId = currentCategoryId, brandId = currentBrandId, sort = currentSort, page = currentPage - 1 })">
                                &laquo; Trước
                            </a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link"
                                   href="@Url.Action("Index", new { search = currentSearch, categoryId = currentCategoryId, brandId = currentBrandId, sort = currentSort, page = i })">
                                    @i
                                </a>
                            </li>
                        }
                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { search = currentSearch, categoryId = currentCategoryId, brandId = currentBrandId, sort = currentSort, page = currentPage + 1 })">
                                Sau &raquo;
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applySortFilter(sortValue) {
            var url = new URL(window.location.href);
            url.searchParams.set('sort', sortValue);
            url.searchParams.delete('page');
            window.location.href = url.toString();
        }
    </script>
}
